---
import Layout from "../../components/Layout.astro";
---

<Layout
  title="TTDSG-Cookie-Check"
  description="Schnellprüfung Ihrer Website auf Tracking-Cookies, Marketing-Skripte und Consent-Banner. Kostenlos, ohne Anmeldung."
>
  <section class="max-w-(--container-wide) mx-auto px-6 py-16">
    <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Mini-Tool</div>
    <h1 class="font-serif text-4xl md:text-5xl text-ink mb-4 max-w-3xl">TTDSG-Cookie-Check.</h1>
    <p class="text-lg text-ink-soft max-w-2xl leading-relaxed mb-8">
      Wir laden Ihre Seite, lesen die gesetzten Cookies und prüfen auf bekannte
      Tracking-Skripte (Google Analytics, Facebook Pixel, Hotjar, &hellip;).
      In 5 Sekunden wissen Sie, ob Ihre Seite groben Cookie-Banner-Bedarf hat.
    </p>

    <div class="grid md:grid-cols-[2fr_1fr] gap-12">
      <form id="cookie-form" class="space-y-4">
        <div>
          <label for="url" class="block text-sm text-ink-soft mb-2">Vollständige URL inkl. https://</label>
          <input
            id="url"
            name="url"
            type="url"
            required
            placeholder="https://www.beispiel.de"
            class="w-full px-4 py-2 border border-line rounded bg-paper focus:outline-none focus:border-brand"
          />
        </div>
        <button id="cookie-submit" type="submit" class="px-6 py-3 bg-ink text-paper rounded-full hover:bg-brand disabled:opacity-50">Scan starten</button>
        <p id="cookie-status" class="text-sm" role="status" aria-live="polite"></p>
      </form>

      <aside class="text-sm text-ink-soft space-y-4">
        <div>
          <h2 class="font-serif text-lg text-ink mb-1">Was wir prüfen</h2>
          <ul class="space-y-1">
            <li>HTTP-gesetzte Cookies und ihre Flags (Secure, HttpOnly, SameSite)</li>
            <li>Eingebundene Marketing-Skripte (GA4, Pixel, &hellip;)</li>
            <li>Anzeichen für Consent-Banner (OneTrust, Cookiebot, Borlabs, &hellip;)</li>
          </ul>
        </div>
        <div>
          <h2 class="font-serif text-lg text-ink mb-1">Was wir nicht prüfen</h2>
          <ul class="space-y-1">
            <li>JavaScript-gesetzte Cookies (kein Headless-Browser)</li>
            <li>Ob Consent korrekt eingeholt wird</li>
            <li>Verträge mit Trackern (AVV/SCC)</li>
          </ul>
          <p class="mt-2 text-xs text-ink-muted">Für Vollaudit: <a href="/kontakt" class="text-brand">Pilot anfragen</a>.</p>
        </div>
      </aside>
    </div>

    <div id="cookie-result" class="mt-12"></div>
  </section>
</Layout>

<script>
  type CookieBefund = { name: string; klassifizierung: string; secure: boolean; httponly: boolean; samesite: string };
  type ScriptBefund = { src: string; klassifizierung: string };
  type Ergebnis = {
    url: string;
    final_url: string;
    cookies: CookieBefund[];
    scripts: ScriptBefund[];
    consent_banner_erkannt: boolean;
    consent_marker: string[];
    score: number;
    empfehlungen: string[];
  };

  const form = document.getElementById("cookie-form") as HTMLFormElement | null;
  const urlInput = document.getElementById("url") as HTMLInputElement | null;
  const submitBtn = document.getElementById("cookie-submit") as HTMLButtonElement | null;
  const statusEl = document.getElementById("cookie-status") as HTMLParagraphElement | null;
  const resultEl = document.getElementById("cookie-result") as HTMLDivElement | null;

  function badge(text: string, color: string) {
    return `<span class="inline-block px-2 py-0.5 text-xs rounded ${color}">${text}</span>`;
  }

  function colorFor(k: string) {
    if (k === "marketing") return "bg-red-100 text-red-800";
    if (k === "funktional") return "bg-amber-100 text-amber-800";
    if (k === "essenziell") return "bg-emerald-100 text-emerald-800";
    return "bg-gray-100 text-gray-700";
  }

  function render(e: Ergebnis) {
    if (!resultEl) return;
    const scoreColor = e.score >= 80 ? "text-emerald-700" : e.score >= 60 ? "text-amber-700" : "text-red-700";
    resultEl.innerHTML = `
      <div class="border border-line rounded p-6 bg-paper">
        <h2 class="font-serif text-2xl text-ink mb-3">Ergebnis: <span class="${scoreColor}">${e.score}/100</span></h2>
        <p class="text-sm text-ink-soft mb-4">Geprüft: <strong>${e.final_url}</strong> ${e.consent_banner_erkannt ? badge("Consent-Banner erkannt: " + e.consent_marker.join(", "), "bg-emerald-100 text-emerald-800") : badge("kein Consent-Banner erkannt", "bg-red-100 text-red-800")}</p>

        <h3 class="font-medium text-ink mt-6 mb-2">Cookies (${e.cookies.length})</h3>
        ${e.cookies.length === 0 ? '<p class="text-sm text-ink-muted">Keine HTTP-Cookies gesetzt.</p>' : `
        <ul class="text-sm space-y-1">${e.cookies.map(c => `
          <li class="flex flex-wrap items-center gap-2">
            <code class="bg-gray-50 px-1.5 py-0.5 rounded text-xs">${c.name}</code>
            ${badge(c.klassifizierung, colorFor(c.klassifizierung))}
            ${c.secure ? "" : badge("kein Secure-Flag", "bg-red-100 text-red-800")}
            ${c.samesite ? "" : badge("kein SameSite", "bg-amber-100 text-amber-800")}
          </li>`).join("")}</ul>`}

        <h3 class="font-medium text-ink mt-6 mb-2">Tracking-Skripte (${e.scripts.length})</h3>
        ${e.scripts.length === 0 ? '<p class="text-sm text-ink-muted">Keine bekannten Marketing-Skripte erkannt.</p>' : `
        <ul class="text-sm space-y-1">${e.scripts.map(s => `<li><code class="bg-gray-50 px-1.5 py-0.5 rounded text-xs break-all">${s.src}</code></li>`).join("")}</ul>`}

        <h3 class="font-medium text-ink mt-6 mb-2">Empfehlungen</h3>
        <ul class="text-sm space-y-1.5">
          ${e.empfehlungen.map(emp => `<li>• ${emp}</li>`).join("")}
        </ul>

        <p class="text-xs text-ink-muted mt-6">Heuristische Schnellprüfung. Kein Audit-Ersatz. Lust auf eine vollständige Compliance-Analyse? <a href="/kontakt" class="text-brand">Pilot anfragen</a>.</p>
      </div>
    `;
  }

  if (form && submitBtn && statusEl && urlInput && resultEl) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      statusEl.className = "text-sm text-ink-soft";
      statusEl.textContent = "Scan läuft …";
      submitBtn.disabled = true;
      resultEl.innerHTML = "";
      try {
        const res = await fetch("/api/tools/cookie-check/", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url: urlInput.value.trim() }),
        });
        if (res.ok) {
          const data = (await res.json()) as Ergebnis;
          render(data);
          statusEl.textContent = "";
        } else if (res.status === 429) {
          statusEl.className = "text-sm text-red-600";
          statusEl.textContent = "Zu viele Scans. Bitte in einer Stunde erneut versuchen.";
        } else {
          const data = await res.json().catch(() => null) as { detail?: string } | null;
          statusEl.className = "text-sm text-red-600";
          statusEl.textContent = data?.detail ?? "Scan fehlgeschlagen.";
        }
      } catch {
        statusEl.className = "text-sm text-red-600";
        statusEl.textContent = "Netzwerkfehler.";
      } finally {
        submitBtn.disabled = false;
      }
    });
  }
</script>
