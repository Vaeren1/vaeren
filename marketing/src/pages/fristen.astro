---
import Layout from "../components/Layout.astro";
import FristenTimeline from "../components/FristenTimeline.tsx";
import { FRISTEN } from "../data/fristen";
---

<Layout
  title="Fristen-Kalender"
  description="Compliance-Stichtage 2023 bis 2029. AI Act, NIS2, CSDDD, HinSchG, CSRD, GwG und mehr."
>
  <section class="max-w-(--container-wide) mx-auto px-6 py-12 md:py-16">
    <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Fristen-Kalender</div>
    <h1 class="font-serif text-4xl md:text-5xl text-ink mb-4 max-w-3xl">Compliance-Stichtage im Überblick.</h1>
    <p class="text-lg text-ink-soft max-w-2xl leading-relaxed mb-10">
      Alle relevanten Fristen aus AI Act, NIS2, CSDDD, HinSchG, CSRD und weiteren Regulierungen. Vergangene Fristen sind ausgeblendet, lassen sich mit einem Klick einsehen.
    </p>
    <FristenTimeline fristen={FRISTEN} client:load />
  </section>
</Layout>
