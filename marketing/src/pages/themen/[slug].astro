---
import Layout from "../../components/Layout.astro";
import NewsCard from "../../components/NewsCard.astro";
import { HUBS, getHub } from "../../data/themen";
import { fristenForHub } from "../../data/fristen";
import { fetchNewsList } from "../../lib/api";
import { formatDate } from "../../lib/format";

export async function getStaticPaths() {
  return HUBS.map((h) => ({ params: { slug: h.slug } }));
}

const { slug } = Astro.params;
const hub = getHub(slug as "ai-act" | "hinschg" | "nis2");
const allPosts = await fetchNewsList();
const hubPosts = allPosts
  .filter((p) => p.kategorie === hub.kategorie)
  .sort((a, b) => (b.published_at ?? "").localeCompare(a.published_at ?? ""))
  .slice(0, 6);
const fristen = fristenForHub(hub.slug);
const today = new Date().toISOString().slice(0, 10);
---

<Layout
  title={hub.titel}
  description={hub.untertitel}
>
  <section class="border-b border-line">
    <div class="max-w-(--container-wide) mx-auto px-6 py-16">
      <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Themen-Hub</div>
      <h1 class="font-serif text-4xl md:text-5xl text-ink mb-4">{hub.titel}</h1>
      <p class="text-xl text-ink-soft max-w-3xl leading-relaxed">{hub.untertitel}</p>
      <div class="mt-8 p-5 bg-paper-soft border-l-4 border-brand rounded-r max-w-(--container-prose)">
        <div class="text-xs uppercase tracking-widest text-ink-muted mb-1">Aktueller Stand · {formatDate(hub.stand_datum)}</div>
        <p class="text-ink-soft leading-relaxed">{hub.status_satz}</p>
      </div>
    </div>
  </section>

  <section class="max-w-(--container-wide) mx-auto px-6 py-16">
    <h2 class="font-serif text-2xl text-ink mb-8">Wer ist betroffen?</h2>
    <div class="grid md:grid-cols-2 gap-4 max-w-(--container-wide)">
      {hub.wer_betroffen.map(b => (
        <div class="p-5 border border-line rounded-lg">
          <div class="font-medium text-ink mb-2">{b.aspekt}</div>
          <p class="text-sm text-ink-soft leading-relaxed">{b.wert}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-line bg-paper-soft/40">
    <div class="max-w-(--container-wide) mx-auto px-6 py-16">
      <h2 class="font-serif text-2xl text-ink mb-8">Pflichten im Überblick</h2>
      <div class="space-y-4 max-w-(--container-wide)">
        {hub.pflichten.map((p, i) => (
          <article class="grid grid-cols-[40px_1fr_auto] gap-4 items-start p-5 bg-paper border border-line rounded-lg">
            <div class="w-10 h-10 rounded-full bg-ink text-paper font-serif flex items-center justify-center">{i + 1}</div>
            <div>
              <div class="font-medium text-ink mb-1">{p.titel}</div>
              <p class="text-sm text-ink-soft leading-relaxed">{p.kurz}</p>
            </div>
            <div class="text-xs uppercase tracking-widest text-brand whitespace-nowrap text-right">{p.frist}</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {fristen.length > 0 && (
    <section class="border-t border-line">
      <div class="max-w-(--container-wide) mx-auto px-6 py-16">
        <h2 class="font-serif text-2xl text-ink mb-2">Wichtige Stichtage</h2>
        <p class="text-ink-muted mb-8 text-sm">Auszug aus dem <a href="/fristen" class="text-brand no-underline hover:underline">vollständigen Fristen-Kalender</a>.</p>
        <ul class="space-y-3 max-w-(--container-wide)">
          {fristen.map(f => {
            const past = f.datum < today;
            return (
              <li class={`flex flex-wrap items-baseline gap-x-4 gap-y-1 py-3 border-b border-line ${past ? "opacity-60" : ""}`}>
                <span class="font-serif text-lg text-ink min-w-[180px]">{formatDate(f.datum)}</span>
                <span class="font-medium text-ink flex-1 min-w-[300px]">{f.titel}</span>
                <a href={f.quelle_url} class="text-xs no-underline border-b border-line hover:border-brand hover:text-brand" rel="external nofollow">Quelle</a>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  {hubPosts.length > 0 && (
    <section class="border-t border-line bg-paper-soft/40">
      <div class="max-w-(--container-wide) mx-auto px-6 py-16">
        <div class="flex items-end justify-between mb-8">
          <h2 class="font-serif text-2xl text-ink">Aktuelle Entwicklungen</h2>
          <a href={`/news?kategorie=${hub.kategorie}`} class="text-sm no-underline border-b border-ink hover:border-brand hover:text-brand">Alle {hub.titel}-Beiträge →</a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {hubPosts.map(post => <NewsCard post={post} variant="compact" />)}
        </div>
      </div>
    </section>
  )}

  <section class="border-t border-line">
    <div class="max-w-(--container-wide) mx-auto px-6 py-16">
      <h2 class="font-serif text-2xl text-ink mb-8">Häufige Fragen</h2>
      <div class="space-y-4 max-w-(--container-prose)">
        {hub.faq.map(f => (
          <details class="border border-line rounded-lg group">
            <summary class="cursor-pointer p-5 font-medium text-ink list-none flex items-start justify-between gap-4">
              <span>{f.frage}</span>
              <span class="text-ink-muted group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="px-5 pb-5 -mt-1 text-ink-soft leading-relaxed">{f.antwort}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-line bg-paper-soft/40">
    <div class="max-w-(--container-wide) mx-auto px-6 py-16">
      <h2 class="font-serif text-2xl text-ink mb-6">Weiterführende Quellen</h2>
      <ul class="space-y-2 max-w-(--container-prose)">
        {hub.weiterfuehrend.map(w => (
          <li>
            <a href={w.url} class="text-brand no-underline hover:underline" rel="external">{w.titel}</a>
            <span class="block text-xs text-ink-muted break-all">{w.url}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
