---
import Layout from "../components/Layout.astro";
import RegulierungsMatrix from "../components/RegulierungsMatrix.astro";
import { LEISTUNGEN } from "../data/leistungen";
---

<Layout
  title="Produkt"
  description="Zehn Module von Pflichtunterweisung bis ISO 27001 — welche Pflicht, welches Modul. Eine Plattform, ein Compliance-Index."
>
  <section class="max-w-(--container-wide) mx-auto px-6 py-16">
    <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Produkt</div>
    <h1 class="font-serif text-4xl md:text-5xl text-ink mb-4 max-w-3xl">Zehn Module. Eine Plattform. Alle Pflichten.</h1>
    <p class="text-lg text-ink-soft max-w-2xl mb-12 leading-relaxed">
      Vaeren bündelt die wiederkehrenden Compliance-Lasten des Industrie-Mittelstands in einer integrierten Software. Modulübergreifender Compliance-Index, gemeinsames Audit-Log, eine Anmeldung.
    </p>

    {/* Einstieg über die Pflicht: Welche Regulierung → welches Modul. */}
    <section class="mb-20">
      <h2 class="font-serif text-3xl text-ink mb-2">Welche Pflicht — welches Modul?</h2>
      <p class="text-ink-soft mb-6 max-w-2xl">Der vollständige Regulierungs-Katalog, gegen den auch der <a href="/schnell-check">Schnell-Check</a> prüft — mit ehrlicher Auskunft, wie tief Vaeren jede Pflicht heute abdeckt.</p>
      <RegulierungsMatrix />
    </section>

    <div class="space-y-20">
      {LEISTUNGEN.map((l, idx) => (
        <article id={l.id} class="grid md:grid-cols-12 gap-10 border-t border-line pt-12">
          <div class="md:col-span-4">
            <div class="text-xs uppercase tracking-widest text-ink-muted mb-2">Modul {idx + 1}</div>
            <h2 class="font-serif text-3xl text-ink mb-3">{l.titel}</h2>
            <p class="text-ink-soft leading-relaxed">{l.einzeiler}</p>
            <div class="mt-6 text-xs uppercase tracking-widest text-ink-muted">Rechtlicher Bezug</div>
            <p class="text-sm text-ink-soft mt-1">{l.bezug}</p>
          </div>
          <div class="md:col-span-8 space-y-6">
            <p class="text-lg text-ink-soft leading-relaxed">{l.details}</p>
            <div>
              <div class="text-xs uppercase tracking-widest text-brand font-medium mb-3">Features</div>
              <ul class="space-y-2 text-ink-soft">
                {l.beweise.map(b => (
                  <li class="flex gap-3"><span class="text-brand mt-1.5">▸</span><span>{b}</span></li>
                ))}
              </ul>
            </div>
            <div class="bg-paper-soft border-l-4 border-brand p-5 rounded-r">
              <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Aus der Praxis</div>
              <p class="text-sm text-ink-soft leading-relaxed">{l.use_case}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="mt-20 p-8 border border-line rounded-lg bg-ink text-paper flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div>
        <h2 class="font-serif text-2xl">Demo gewünscht?</h2>
        <p class="mt-2 text-paper/80">30 Minuten Live-Tour durch die Plattform. Wir zeigen den Compliance-Radar, den Compliance-Index und die Module, die Ihr Schnell-Check-Ergebnis betreffen.</p>
      </div>
      <a href="/kontakt" class="inline-flex items-center px-6 py-3 bg-paper text-ink no-underline rounded-full hover:bg-paper-soft">Termin vereinbaren →</a>
    </section>
  </section>
</Layout>
