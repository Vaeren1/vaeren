---
import Layout from "../components/Layout.astro";
import RadarTeaser from "../components/RadarTeaser.astro";
import TrustBadges from "../components/TrustBadges.astro";
import NewsCard from "../components/NewsCard.astro";
import NewsTicker from "../components/NewsTicker.astro";
import RegulierungsMatrix from "../components/RegulierungsMatrix.astro";
import { Image } from "astro:assets";
import { fetchNewsList, KATEGORIE_LABELS } from "../lib/api";
import { HUBS } from "../data/themen";

// Produktbeweis: Screenshots aus dem Demo-Tenant (scripts/screenshots.mjs).
// Sektion erscheint nur, wenn Bilder vorhanden sind.
const screenshotModules = import.meta.glob<{ default: ImageMetadata }>("../assets/screenshots/*.png", { eager: true });
const SHOT_LABELS: Record<string, string> = {
  "cockpit.png": "Compliance-Cockpit: Index, Aufgaben, Fristen auf einen Blick",
  "wizard.png": "Onboarding-Wizard: in fünf Schritten zur Compliance-Landkarte",
  "fragebogen.png": "OEM-Fragebogen-Auswerter: Auto-Antworten mit Attestierung",
};
const SHOT_REIHENFOLGE = ["cockpit.png", "wizard.png", "fragebogen.png"];
const screenshots = Object.entries(screenshotModules)
  .map(([pfad, mod]) => ({ datei: pfad.split("/").pop()!, bild: mod.default }))
  .sort((a, b) => SHOT_REIHENFOLGE.indexOf(a.datei) - SHOT_REIHENFOLGE.indexOf(b.datei));

const posts = await fetchNewsList();
const teaserPosts = posts
  .sort((a, b) => {
    if (a.pinned !== b.pinned) return a.pinned ? -1 : 1;
    const order: Record<string, number> = { hoch: 0, mittel: 1, niedrig: 2 };
    if (a.relevanz !== b.relevanz)
      return (order[a.relevanz] ?? 3) - (order[b.relevanz] ?? 3);
    return (b.published_at ?? "").localeCompare(a.published_at ?? "");
  })
  .slice(0, 6);
---

<Layout
  title="Vaeren"
  description="Vaeren ist der Compliance-Autopilot für den industriellen Mittelstand. Pflichtunterweisungen, HinSchG-Hinweisgeberportal und Compliance-Cockpit aus einer Hand."
>
  {/* News-Ticker direkt unter dem Menü: rotierende aktuelle Beiträge. */}
  <NewsTicker posts={teaserPosts} />

  {/* Hero: Erklärung + Benefit-Checkliste links, animierter Radar-Teaser
      rechts. Schnell-Check-Einstieg bewusst NUR im Teaser (kein Doppel-CTA). */}
  <section class="border-b border-line">
    <div class="max-w-(--container-wide) mx-auto px-6 py-12 md:py-16 grid lg:grid-cols-[1fr_1.05fr] gap-12 items-start">
      <div class="lg:pt-4">
        <div class="text-xs uppercase tracking-widest text-brand font-medium mb-5">Compliance-Autopilot für den Mittelstand</div>
        <h1 class="font-serif text-4xl md:text-5xl leading-[1.05] text-ink">Compliance läuft.<br />Ihr Geschäft auch.</h1>
        <p class="mt-5 text-lg text-ink-soft leading-relaxed">Vaeren ist der Compliance-Autopilot für den Mittelstand: Die Software zeigt, welche Pflichten Ihren Betrieb treffen, erledigt die wiederkehrende Arbeit dahinter und hält jeden Nachweis auditfest bereit.</p>
        <p class="mt-3 text-base text-ink-soft leading-relaxed">Ob mit eigener Compliance-Abteilung oder neben dem Tagesgeschäft: Vaeren bündelt Schulungen, Hinweisgeberportal, Risikobewertungen und Register in einer Plattform, überwacht jede Frist und erstellt die Dokumentation, die Prüfer und Kunden sehen wollen.</p>
        <p class="mt-3 text-base text-ink-soft leading-relaxed">AI Act, NIS2, CSRD und HinSchG machen Compliance gerade zur Chefsache. Mit Vaeren beantworten Sie sie ohne Beraterhonorare und ohne Excel-Listen.</p>
        <svg width="0" height="0" aria-hidden="true"><defs><linearGradient id="check-v" x1="0" y1="1" x2="1" y2="0"><stop offset="0%" stop-color="#0F4C5C"></stop><stop offset="100%" stop-color="#B45309"></stop></linearGradient></defs></svg>
        <ul class="mt-6 space-y-3">
          {[
            "Alle Pflichten und Fristen in einem Cockpit",
            "Nachweise auditfest, Export auf Knopfdruck",
            "Hosting in Deutschland, jede Entscheidung trifft ein Mensch",
          ].map(punkt => (
            <li class="flex items-start gap-3 text-ink">
              <svg width="18" height="18" viewBox="0 0 48 48" class="flex-shrink-0 mt-1" aria-hidden="true"><path d="M8,16 L22,40 L42,8" fill="none" stroke="url(#check-v)" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              <span>{punkt}</span>
            </li>
          ))}
        </ul>
        <a href="/kontakt" class="mt-8 inline-flex items-center gap-2 px-7 py-3.5 bg-brand text-paper font-medium no-underline rounded-full shadow-sm shadow-brand/30 hover:bg-ink transition-all">Demo anfragen →</a>
      </div>
      <RadarTeaser />
    </div>
  </section>

  {/* Zahlenband — echte Produktzahlen als Kompetenzbeweis. */}
  <section class="border-b border-line bg-paper-soft/40">
    <div class="max-w-(--container-wide) mx-auto px-6 py-6 grid grid-cols-2 md:grid-cols-5 gap-4 text-center">
      {[["24", "Branchen im Schnell-Check"], ["20", "Pflicht-Kurse"], ["93", "ISO-Controls"], ["16", "Regulierungen im Katalog"], ["DE", "Hosting"]].map(([zahl, label]) => (
        <div><div class="font-serif text-3xl text-brand font-semibold">{zahl}</div><div class="text-xs uppercase tracking-widest text-ink-muted mt-1">{label}</div></div>
      ))}
    </div>
  </section>

  {/* News-Sektion direkt nach Hero. Größere Vorschau (6 Posts statt 3). */}
  <section class="max-w-(--container-wide) mx-auto px-6 py-14 md:py-20">
    <div class="flex items-end justify-between gap-4 mb-8">
      <div>
        <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Aktuelles</div>
        <h2 class="font-serif text-3xl md:text-4xl text-ink">Rechtsentwicklungen, kuratiert.</h2>
      </div>
      <a href="/news" class="text-sm no-underline border-b border-ink hover:border-brand hover:text-brand whitespace-nowrap">Alle Beiträge →</a>
    </div>
    {teaserPosts.length === 0 ? (
      <p class="text-ink-muted">Beiträge erscheinen in Kürze.</p>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {teaserPosts.map(post => <NewsCard post={post} variant="compact" />)}
      </div>
    )}
  </section>

  {/* Themen-Hubs Teaser direkt unter Aktuelles. */}
  <section class="border-t border-line bg-paper-soft/30">
    <div class="max-w-(--container-wide) mx-auto px-6 py-14 md:py-20">
      <div class="flex items-end justify-between gap-4 mb-8">
        <div>
          <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Themen-Hubs</div>
          <h2 class="font-serif text-3xl md:text-4xl text-ink">Living Documents zu den großen Pflichten.</h2>
        </div>
        <a href="/themen" class="text-sm no-underline border-b border-ink hover:border-brand hover:text-brand whitespace-nowrap">Alle Themen →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {HUBS.slice(0, 3).map(h => (
          <a href={`/themen/${h.slug}`} class="block group no-underline">
            <article class="h-full p-5 bg-paper border border-line rounded-lg hover:border-brand hover:shadow-sm transition-all space-y-3">
              <div class="flex items-center gap-2">
                <span class={`pill pill-${h.kategorie}`}>{KATEGORIE_LABELS[h.kategorie]}</span>
              </div>
              <h3 class="font-serif text-xl text-ink group-hover:text-brand">{h.titel}</h3>
              <p class="text-sm text-ink-soft leading-relaxed line-clamp-3">{h.status_satz}</p>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Module-Pitch: Einstieg über die Pflicht (kompakte Matrix-Vorschau). */}
  <section class="max-w-(--container-wide) mx-auto px-6 py-14 md:py-20">
    <div class="flex items-end justify-between gap-4 mb-8">
      <div>
        <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Was Vaeren tut</div>
        <h2 class="font-serif text-3xl md:text-4xl text-ink max-w-3xl">Eine Plattform, alle Pflichten.</h2>
      </div>
      <a href="/leistungen" class="text-sm no-underline border-b border-ink hover:border-brand hover:text-brand whitespace-nowrap">Alle Module & Abdeckung →</a>
    </div>
    <RegulierungsMatrix kompakt />
  </section>

  {/* Produktbeweis: echte App-Screenshots aus dem Demo-Mandanten. */}
  {screenshots.length > 0 && (
    <section class="border-t border-line bg-paper-soft/30">
      <div class="max-w-(--container-wide) mx-auto px-6 py-14 md:py-20">
        <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Produktbeweis</div>
        <h2 class="font-serif text-3xl md:text-4xl text-ink mb-10">So sieht Vaeren wirklich aus.</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {screenshots.map(({ datei, bild }) => (
            <figure class="bg-paper border border-line rounded-lg overflow-hidden shadow-sm">
              <div class="flex gap-1.5 px-3 py-2 border-b border-line bg-paper-soft">
                <span class="w-2 h-2 rounded-full bg-line"></span><span class="w-2 h-2 rounded-full bg-line"></span><span class="w-2 h-2 rounded-full bg-line"></span>
              </div>
              <Image src={bild} alt={SHOT_LABELS[datei] ?? datei} class="w-full h-auto" widths={[480, 800]} sizes="(max-width: 768px) 100vw, 33vw" />
              <figcaption class="px-4 py-3 text-sm text-ink-soft">{SHOT_LABELS[datei] ?? ""}</figcaption>
            </figure>
          ))}
        </div>
        <p class="mt-4 text-xs text-ink-muted">Screenshots aus dem Demo-Mandanten, keine Mockups.</p>
      </div>
    </section>
  )}

  {/* Trust-Badges, dezent als horizontaler Streifen. */}
  <TrustBadges />

  {/* Warum jetzt-Block. */}
  <section class="border-t border-line">
    <div class="max-w-(--container-wide) mx-auto px-6 py-14 md:py-20 grid md:grid-cols-2 gap-12 items-start">
      <div>
        <div class="text-xs uppercase tracking-widest text-brand font-medium mb-2">Warum 2026</div>
        <h2 class="font-serif text-3xl md:text-4xl text-ink">Compliance war noch nie so dicht.</h2>
      </div>
      <div class="space-y-5 text-ink-soft leading-relaxed">
        <p>AI Act, NIS2, CSDDD, HinSchG, CSRD. Fünf große Regulierungs-Pakete fallen 2026 und 2027 zeitgleich auf den Schreibtisch der Geschäftsführung. Jedes mit eigenen Fristen, eigenen Berichts-Formaten, eigener Aufsichtsbehörde.</p>
        <p>Im Industrie-Mittelstand fehlt die Schicht aus Stabsstellen, die das in Konzernen abfedert. Die Compliance-Beauftragte ist oft die HR-Leitung in Personalunion. Externe Beratung kostet 1.500 EUR pro Tag und löst nichts strukturell.</p>
        <p>Vaeren übernimmt die wiederkehrende Arbeit. Dokumentations-Pflichten, Fristen-Überwachung, Berichts-Vorbereitung, Schulungen, Hinweisgeberkanäle. Sie behalten den Überblick, statt ständig im Reaktiv-Modus zu rennen.</p>
        <a href="/fristen" class="inline-flex items-center gap-2 mt-2 text-sm no-underline border-b border-ink hover:border-brand hover:text-brand">Alle Fristen ansehen →</a>
      </div>
    </div>
  </section>

  {/* Final CTA. */}
  <section class="border-t border-line bg-ink text-paper">
    <div class="max-w-(--container-wide) mx-auto px-6 py-14 md:py-20 flex flex-col md:flex-row md:items-center justify-between gap-8">
      <div>
        <h2 class="font-serif text-3xl md:text-4xl">Pilot werden.</h2>
        <p class="mt-4 text-paper/80 max-w-xl">Wir suchen Industrie-Mittelständler mit 50 bis 300 Mitarbeitenden für die Pilotphase 2026. 40 % Pilot-Rabatt, gemeinsame Produktentwicklung, direkter Draht zur Gründung.</p>
      </div>
      <a href="/kontakt" class="inline-flex items-center gap-2 px-7 py-3.5 bg-paper text-ink font-medium no-underline rounded-full hover:bg-brand hover:text-paper transition-colors">Gespräch vereinbaren →</a>
    </div>
  </section>
</Layout>
