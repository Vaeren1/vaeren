---
import type { NewsPostListItem } from "../lib/api";
import KategoriePill from "./KategoriePill.astro";
import KategorieGrafik from "./KategorieGrafik.astro";
import GeoTag from "./GeoTag.astro";
import { formatDateShort } from "../lib/format";

interface Props {
  post: NewsPostListItem;
  variant?: "compact" | "default" | "related";
}

const { post, variant = "default" } = Astro.props;
const href = `/news/${post.slug}`;
---

{variant === "compact" && (
  <a href={href} class="block group no-underline">
    <article class="border border-line rounded-lg hover:border-brand hover:bg-paper-soft transition-colors h-full overflow-hidden">
      <KategorieGrafik kategorie={post.kategorie} klasse="h-24" />
      <div class="space-y-3 p-5">
        <div class="flex items-center gap-3">
          <KategoriePill kategorie={post.kategorie} />
          <GeoTag geo={post.geo} />
        </div>
        <h3 class="font-serif text-xl text-ink leading-snug group-hover:text-brand">{post.titel}</h3>
        <p class="text-sm text-ink-muted line-clamp-3">{post.lead}</p>
        <div class="text-xs text-ink-muted pt-2">{formatDateShort(post.published_at)}</div>
      </div>
    </article>
  </a>
)}

{variant === "default" && (
  <a href={href} class="block group no-underline">
    <article class="py-7 border-b border-line grid md:grid-cols-[180px_1fr] gap-6 items-start">
      <div class="hidden md:block rounded-lg overflow-hidden border border-line">
        <KategorieGrafik kategorie={post.kategorie} klasse="h-24" />
      </div>
      <div>
        <div class="flex items-center gap-3 mb-3">
          <KategoriePill kategorie={post.kategorie} />
          <GeoTag geo={post.geo} />
          <span class="text-xs text-ink-muted">{formatDateShort(post.published_at)}</span>
          {post.pinned && (
            <span class="text-xs uppercase tracking-wide text-accent-warm">Angepinnt</span>
          )}
        </div>
        <h2 class="font-serif text-2xl text-ink leading-snug group-hover:text-brand mb-2">{post.titel}</h2>
        <p class="text-base text-ink-soft leading-relaxed">{post.lead}</p>
      </div>
    </article>
  </a>
)}

{variant === "related" && (
  <a href={href} class="block group no-underline">
    <article class="space-y-2 p-4 border-l-2 border-line group-hover:border-brand">
      <KategoriePill kategorie={post.kategorie} />
      <h4 class="font-serif text-base text-ink group-hover:text-brand">{post.titel}</h4>
      <p class="text-xs text-ink-muted line-clamp-2">{post.lead}</p>
    </article>
  </a>
)}
