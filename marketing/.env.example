# Marketing-Site Build-Env. Pro Umgebung anders.
#
# Dev:  PUBLIC_API_BASE=http://localhost:8000
# Prod: PUBLIC_API_BASE=https://api.vaeren.de
#
# Wird zur Build-Zeit von Astro gelesen und in den statischen Build
# eingebrannt. Änderungen erfordern Neu-Build.

PUBLIC_API_BASE=http://localhost:8000

# Plausible Analytics — Domain-Identifier. Setzen sobald stats.vaeren.de
# läuft (Prod: vaeren.de). Leer lassen, um das Script vollständig zu
# deaktivieren (z.B. in dev).
PUBLIC_PLAUSIBLE_DOMAIN=
