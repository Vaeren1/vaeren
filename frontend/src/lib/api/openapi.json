        "/api/auth/csrf/": {
            "get": {
                "operationId": "auth_csrf_retrieve",
                "description": "Liefert CSRF-Token + setzt csrftoken-Cookie.\n\nFrontend ruft diesen Endpoint einmal beim App-Start, liest den Cookie\naus und setzt für unsichere Methoden den `X-CSRFToken`-Header.",
