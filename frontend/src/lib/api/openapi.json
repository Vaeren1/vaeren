    "components": {
        "schemas": {
            "ComplianceTask": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "polymorphic_ctype": {
                        "type": "string",
                        "description": "Wert wird in Sprint 4+ relevant, wenn Subklassen existieren.",
                        "readOnly": true
                    },
                    "titel": {
                        "type": "string",
                        "readOnly": true
                    },
                    "modul": {
                        "type": "string",
                        "readOnly": true,
                        "description": "Modul-Identifier (z. B. 'pflichtunterweisung', 'hinschg')"
                    },
                    "kategorie": {
                        "type": "string",
                        "readOnly": true
                    },
                    "frist": {
                        "type": "string",
                        "format": "date",
                        "readOnly": true
                    },
                    "verantwortlicher": {
                        "type": "integer",
                        "readOnly": true,
                        "nullable": true
                    },
                    "betroffene": {
                        "type": "array",
                        "items": {
                            "type": "integer"
                        },
                        "readOnly": true
                    },
                    "status": {
                        "allOf": [
                            {
                                "$ref": "#/components/schemas/StatusEnum"
                            }
                        ],
                        "readOnly": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    }
                },
                "required": [
                    "betroffene",
                    "created_at",
                    "frist",
                    "id",
                    "kategorie",
                    "modul",
                    "polymorphic_ctype",
                    "status",
                    "titel",
                    "updated_at",
                    "verantwortlicher"
                ]
            },
            "CsrfTokenResponse": {
                "type": "object",
                "properties": {
                    "csrf_token": {
                        "type": "string"
                    }
                },
                "required": [
                    "csrf_token"
                ]
            },
            "HealthResponse": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "string"
                    },
                    "schema": {
                        "type": "string"
                    }
                },
                "required": [
                    "schema",
                    "status"
                ]
            },
            "Login": {
                "type": "object",
                "properties": {
                    "username": {
