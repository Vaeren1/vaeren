                    "auth"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CsrfTokenResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/auth/login/": {
            "post": {
                "operationId": "auth_login_create",
                "description": "Login mit MFA-Bewusstsein.\n\nAuth-Logik kommt vom `LoginSerializer` (validated_data[\"user\"]). Wir\nhaben dort den User; bevor `django_login` läuft, checken wir das\n`mfa_enabled`-Flag und unterbrechen den Flow falls nötig.",
                "tags": [
                    "auth"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Login"
