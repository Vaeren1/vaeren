# Vaeren Production Caddyfile (Sprint 8).
#
# Lebt auf dem Server unter `/etc/caddy/Caddyfile`.
# Caddy läuft als systemd-Service (`caddy.service`), nicht als Container.
# Caddy bekommt Zugriff auf beide Docker-Networks via `caddy network connect`.
#
# Domains:
#   sponty.fun, www.sponty.fun, api.sponty.fun  → sponty-backend:8000
#   app.vaeren.de                                 → vaeren-django:8000 (API)
#                                                    + vaeren-frontend:80 (SPA)
#   hinweise.app.vaeren.de                        → vaeren-django:8000 (Public-Form)
#                                                    + vaeren-frontend:80 (SPA)
#
# Auto-SSL via Let's Encrypt (HTTP-01-Challenge).
# Kein Wildcard-Cert im MVP (braucht Hetzner-DNS-API-Token, fehlt).

{
    email konradbizer@web.de
    # On-demand-TLS für Self-Service-Tenants (Phase 1.5):
    # Beim ersten Request auf `<tenant>.app.vaeren.de` fragt Caddy bei der
    # `ask`-URL nach, ob der Subdomain bekannt ist. Nur dann wird ein
    # Let's-Encrypt-Cert geholt. Schützt vor Cert-Spam durch unbekannte Hosts.
    on_demand_tls {
        ask http://vaeren-django:8000/api/internal/cert-allowed
    }
}

# --- Sponty ---------------------------------------------------------------
sponty.fun, www.sponty.fun, api.sponty.fun {
    encode gzip zstd

    # API + Admin auf Sponty-Backend
    reverse_proxy sponty-backend:8000 {
        header_up X-Forwarded-Proto https
        header_up X-Real-IP {remote_host}
    }

    # Sponty-Static (Landing-Page) wird vom Backend selbst geliefert (siehe Sponty-Compose).
}


# --- Vaeren Marketing-Site (statisch, Astro-Build) -------------------
# Apex liefert die Astro-Marketing-Site aus /srv/vaeren-marketing/.
# Build erfolgt lokal (deploy.sh: `bun run build` mit PUBLIC_API_BASE=https://api.vaeren.de),
# Output wird per rsync nach /srv/vaeren-marketing gespiegelt.
# www → apex (kanonisch, ein Hostname für SEO).
www.vaeren.de {
    redir https://vaeren.de{uri} permanent
}

vaeren.de {
    encode gzip zstd

    # Astro-Assets sind content-hashed → unendlich cachen
    @astro_assets path /_astro/*
    header @astro_assets Cache-Control "public, max-age=31536000, immutable"

    # HTML kurz cachen, damit Updates schnell durchschlagen
    header Cache-Control "public, max-age=600, must-revalidate"

    # Sicherheits-Header
    header X-Content-Type-Options "nosniff"
    header X-Frame-Options "DENY"
    header Referrer-Policy "strict-origin-when-cross-origin"
    header Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Marketing-Site-Endpoints (Kontakt + Self-Service-Onboarding) → Backend.
    # Same-origin, kein CORS nötig.
    handle /api/kontakt/* {
        reverse_proxy vaeren-django:8000 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
            header_up Host {host}
        }
    }
    handle /api/onboarding/* {
        reverse_proxy vaeren-django:8000 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
            header_up Host {host}
        }
    }
    handle /api/tools/* {
        reverse_proxy vaeren-django:8000 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
            header_up Host {host}
        }
    }

    # Alles andere: statische Marketing-Site
    handle {
        root * /srv/vaeren-marketing
        try_files {path} {path}/index.html /404.html
        file_server
    }

    # Klassische Fehlerseite
    handle_errors {
        rewrite * /404.html
        file_server
    }
}


# --- Vaeren Public-API (für Marketing-Site + andere öffentliche Clients) -
# Mapped via TenantDomain auf das Public-Schema (`ensure_public_domains`-Command).
# Liefert /api/public/news/, /api/public/korrekturen/, /api/public/redaktion/unpublish/<token>/
# und (zukünftig) andere public-only Endpoints.
api.vaeren.de {
    encode gzip zstd
    reverse_proxy vaeren-django:8000 {
        header_up X-Forwarded-Proto https
        header_up X-Real-IP {remote_host}
        header_up Host {host}
    }
}


# --- Vaeren App-Frontend (Haupt-App + Self-Service-Tenants) -------------
# Matched sowohl die statische `app.vaeren.de` (Demo + Marketing-Login)
# als auch `*.app.vaeren.de` (Self-Service-Tenants seit Phase 1.5).
# Wildcards bekommen on-demand-TLS — Caddy fragt das Backend, ob der Host
# als TenantDomain registriert ist, bevor Let's Encrypt kontaktiert wird.
app.vaeren.de, *.app.vaeren.de {
    encode gzip zstd
    tls {
        on_demand
    }

    # API + Admin + Account-Flow → Backend (ASGI/Daphne)
    @api {
        path /api/* /accounts/* /admin /admin/*
    }
    reverse_proxy @api vaeren-django:8000 {
        header_up X-Forwarded-Proto https
        header_up X-Real-IP {remote_host}
        header_up Host {host}
    }

    # Static (Django collectstatic) → Backend
    @django_static {
        path /static/* /media/*
    }
    reverse_proxy @django_static vaeren-django:8000

    # SPA (alles andere) → Frontend-Container (nginx-alpine)
    reverse_proxy vaeren-frontend:80 {
        header_up X-Forwarded-Proto https
    }
}


# --- GlitchTip (Self-hosted Sentry-API) ----------------------------------
# Production-Error-Monitoring. Konrads Daten bleiben EU-side, kein Vendor-Lock.
errors.app.vaeren.de {
    encode gzip zstd
    reverse_proxy glitchtip-web:8000 {
        header_up X-Forwarded-Proto https
        header_up X-Real-IP {remote_host}
        header_up Host {host}
    }
}


# --- Plausible Analytics (self-hosted) ----------------------------------
# Eigener Stack in /opt/plausible/. Caddy muss in plausible-net joinen
# (docker network connect plausible-net caddy).
stats.vaeren.de {
    encode gzip zstd
    reverse_proxy plausible:8000 {
        header_up X-Forwarded-Proto https
        header_up X-Real-IP {remote_host}
        header_up Host {host}
    }
}


# --- Vaeren Public-Hinweisgeber-Portal ------------------------------------
hinweise.app.vaeren.de {
    encode gzip zstd

    # Public-API für Meldung-Submit + Status
    @api {
        path /api/*
    }
    reverse_proxy @api vaeren-django:8000 {
        header_up X-Forwarded-Proto https
        header_up X-Real-IP {remote_host}
        header_up Host {host}
    }

    # Public-Routes /hinweise + /hinweise/status/<token> → Frontend-SPA
    reverse_proxy vaeren-frontend:80 {
        header_up X-Forwarded-Proto https
    }
}
