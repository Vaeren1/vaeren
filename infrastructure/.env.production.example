# Vaeren Production Environment-Variablen — TEMPLATE.
#
# Kopiere dieses File:
#     cp infrastructure/.env.production.example .env.production
# Trage die Werte ein, NIEMALS committen (.gitignore deckt das ab).
# `deploy.sh` lädt es per scp als `.env` auf den Server.

# === Pflicht =============================================================

# Django — generieren via:  python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# ALLOWED_HOSTS für django-tenants — komma-getrennt, OHNE Leerzeichen.
DJANGO_ALLOWED_HOSTS=app.vaeren.de,hinweise.app.vaeren.de,vaeren-django,localhost,127.0.0.1

# CSRF-Origins — schema://host
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.vaeren.de,https://hinweise.app.vaeren.de

# Postgres
POSTGRES_DB=vaeren
POSTGRES_USER=vaeren
POSTGRES_PASSWORD=

# === Optional — alle Module haben Fallbacks (Sprint 4/5/6/8 by-design) ==

# E-Mail-Provider — Brevo ODER Mailjet (Brevo gewinnt wenn beides gesetzt).
# Beide via django-anymail. Fehlt beides → Console-Backend.
# Vor go-live: vaeren.de mit SPF/DKIM/DMARC verifizieren.
#
# Brevo (300 Mails/Tag forever-free, EU-Hosting Frankreich):
BREVO_API_KEY=
#
# Mailjet (200 Mails/Tag forever-free, EU-Hosting Frankreich):
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
VAEREN_FROM_EMAIL=noreply@vaeren.de

# OpenRouter (LLM-Personalisierung). Fehlt → Static-Fallback (Spec §8).
OPENROUTER_API_KEY=

# Sentry-EU (Error-Monitoring). Fehlt → reines Console-Logging.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Logging
DJANGO_LOG_LEVEL=INFO
