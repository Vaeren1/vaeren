<clickhouse>
  <profiles>
    <default>
      <log_queries>0</log_queries>
      <log_query_threads>0</log_query_threads>
    </default>
  </profiles>
  <users>
    <!-- Default-User ohne Passwort, da ClickHouse nur containerintern
         im plausible-net erreichbar ist (kein Port-Mapping nach außen). -->
    <default>
      <password></password>
      <profile>default</profile>
      <quota>default</quota>
      <networks>
        <ip>::/0</ip>
      </networks>
      <access_management>1</access_management>
    </default>
  </users>
</clickhouse>
