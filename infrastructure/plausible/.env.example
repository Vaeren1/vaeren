# Plausible Analytics Production Environment.
# Auf dem Server unter /opt/plausible/.env ablegen (NICHT committen).
#
# Erstellen mit:
#   cd /opt/plausible
#   cp .env.example .env
#   sed -i "s/CHANGE_ME_SECRET/$(openssl rand -hex 32)/" .env
#   sed -i "s/CHANGE_ME_TOTP/$(openssl rand -hex 32)/" .env
#   sed -i "s/CHANGE_ME_DB/$(openssl rand -hex 24)/" .env

BASE_URL=https://stats.vaeren.de
SECRET_KEY_BASE=CHANGE_ME_SECRET
TOTP_VAULT_KEY=CHANGE_ME_TOTP
POSTGRES_PASSWORD=CHANGE_ME_DB
DISABLE_REGISTRATION=true
MAILER_EMAIL=stats@vaeren.de
